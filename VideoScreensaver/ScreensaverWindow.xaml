<Window x:Class="VideoScreensaver.ScreensaverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoScreensaver"
        mc:Ignorable="d"
        Title="VideoScreensaver" WindowStyle="None" ResizeMode="NoResize" Topmost="True" Cursor="None" ShowInTaskbar="False"
        MouseMove="Window_MouseMove" MouseDown="Window_MouseDown" KeyDown="Window_KeyDown">
    <Grid Background="Black">
        <MediaElement Name="ScreensaverVideo" LoadedBehavior="Manual" Loaded="Window_Loaded" MediaEnded="PlayNextVideo"/>
    </Grid>
</Window>
